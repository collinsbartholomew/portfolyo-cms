# MongoDB Configuration
# For Docker Compose with replica set, use all three MongoDB members below.
# The password in MONGODB_URI must exactly match MONGO_ROOT_PASSWORD.
MONGODB_URI=mongodb://admin:CHANGE_THIS_PASSWORD@mongo1:27017,mongo2:27017,mongo3:27017/aiyu?replicaSet=rs0&authSource=admin
# For local development (non-Docker), use: mongodb://localhost:27017/aiyu

# MongoDB Root Credentials (for Docker Compose)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=CHANGE_THIS_PASSWORD
# Shared internal key used by MongoDB replica set members.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
MONGO_REPLICA_SET_KEY=CHANGE_ME_GENERATE_RANDOM_REPLICA_KEY



# N8N Webhook URL
NEXT_PUBLIC_N8N_WEBHOOK_URL=

# Admin Panel Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_MINIMUM_12_CHARS

# JWT Secret
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHAR_STRING

# Blog API Key
BLOG_API_KEY=CHANGE_ME_GENERATE_RANDOM_API_KEY

# Local direct app port for docker-compose-local.yml (optional, defaults to 3000)
APP_PORT=3000

# Production nginx HTTP port for docker-compose.yml (optional, defaults to 80)
NGINX_HTTP_PORT=80

# Optional Node.js memory ceiling
NODE_OPTIONS=--max-old-space-size=512

# SEO Configuration
NEXT_PUBLIC_BASE_URL=http://localhost:3000
SITE_URL=
NEXT_PUBLIC_AUTHOR_NAME=Your Name Here

# Security reminders
# 1. Never commit the actual .env file to git
# 2. Rotate secrets regularly
# 3. Use different secrets for each environment
