{
  "name": "portfolyo-cms",
  "version": "4.1.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "perf:k6:public": "k6 run scripts/k6/public-routes.js",
    "security-check": "node scripts/security-check.mjs",
    "docker:build": "docker-compose build --no-cache",
    "docker:up": "docker-compose up -d",
    "docker:up:dev": "docker compose --env-file .env.production -f docker-compose-local.yml up -d --build",
    "docker:up:prod": "docker compose --env-file .env.production -f docker-compose.yml up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f app",
    "docker:verify": "bash scripts/verify-security.sh",
    "emergency:cleanup": "bash scripts/emergency-cleanup.sh",
    "screenshots:install": "npx playwright install chromium",
    "screenshots:capture": "node scripts/capture-screenshots.mjs",
    "update": "npx npm-check-updates@latest -u"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^2.10.0",
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/typography": "^0.5.20",
    "adm-zip": "^0.5.18",
    "archiver": "^8.0.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "critters": "^0.0.25",
    "date-fns-tz": "^3.2.0",
    "eventemitter3": "^5.0.4",
    "form-data": "^4.0.6",
    "formdata-node": "^6.0.3",
    "framer-motion": "^12.42.0",
    "heic-convert": "^2.1.0",
    "jose": "^6.2.3",
    "js-cookie": "^3.0.8",
    "lodash-es": "^4.18.1",
    "lucide-react": "^1.23.0",
    "mongoose": "^9.7.3",
    "next": "^16.2.9",
    "node-fetch": "^3.3.2",
    "react": "^19.2.7",
    "react-confetti": "^6.4.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-masonry-css": "^1.0.16",
    "react-syntax-highlighter": "^16.1.1",
    "react-vertical-timeline-component": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.35.2",
    "simple-icons": "^16.24.1"
