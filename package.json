    "@tailwindcss/postcss": "^4",
    "eslint": "^10.6.0",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "tailwindcss": "^4",
    "playwright": "^1.61.1"
  },
  "packageManager": "pnpm@11.3.0"
}
